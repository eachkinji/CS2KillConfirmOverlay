<Page
    x:Class="KillConfirmGameBar.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    RequestedTheme="Light">

    <Page.Resources>
        <LinearGradientBrush x:Key="MainBackgroundGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F2F3F2" Offset="0.0" />
            <GradientStop Color="#D8D9D8" Offset="1.0" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="OrangeSlashGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F29A17" Offset="0.0" />
            <GradientStop Color="#EA7F05" Offset="0.55" />
            <GradientStop Color="#DB6900" Offset="1.0" />
        </LinearGradientBrush>

        <AcrylicBrush x:Key="MainBackgroundAcrylic"
                      BackgroundSource="HostBackdrop"
                      TintColor="#F4F4F1"
                      TintOpacity="0.55"
                      FallbackColor="#F4F4F1" />

        <AcrylicBrush x:Key="CardBackgroundAcrylic"
                      BackgroundSource="Backdrop"
                      TintColor="#FAFAF7"
                      TintOpacity="0.88"
                      FallbackColor="#FAFAF7" />

        <Style x:Key="SettingsSectionCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="22" />
            <Setter Property="Background" Value="{StaticResource CardBackgroundAcrylic}" />
            <Setter Property="BorderBrush" Value="#E2DDD3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="24" />
        </Style>

        <Style x:Key="SettingsHeaderButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="MinWidth" Value="104" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#1D2233" />
            <Setter Property="BorderBrush" Value="#D5D0C4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SettingsPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SettingsHeaderButtonStyle}">
            <Setter Property="Background" Value="#2E88B8" />
            <Setter Property="BorderBrush" Value="#3A9CCF" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="SettingsCaptionTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#555966" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
            <Setter Property="LineHeight" Value="20" />
        </Style>

        <Style x:Key="SettingsSectionTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#1B1F31" />
            <Setter Property="CharacterSpacing" Value="40" />
        </Style>

        <Style x:Key="MethodStepCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="14" />
            <Setter Property="Background" Value="#FFFFFC" />
            <Setter Property="BorderBrush" Value="#E2DDD3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <Style x:Key="MethodStepBadgeStyle" TargetType="Border">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Background" Value="#F29A17" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>

        <Style x:Key="MethodStepTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#1B1F31" />
        </Style>

        <Style x:Key="MethodStepBodyTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#555966" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
            <Setter Property="LineHeight" Value="17" />
        </Style>

        <Style x:Key="MethodStepDetailTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#1B1F31" />
        </Style>

        <Style x:Key="MethodStepMonoTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="Foreground" Value="#4B5563" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="LineHeight" Value="16" />
        </Style>

        <Style x:Key="MethodInlineButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Background" Value="#ECF7FC" />
            <Setter Property="Foreground" Value="#2E88B8" />
            <Setter Property="BorderBrush" Value="#B9DCEC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource MainBackgroundGradient}">
        <Canvas IsHitTestVisible="False">
            <Rectangle Width="620" Height="1200" Fill="{StaticResource OrangeSlashGradient}" Opacity="0.95" Canvas.Left="720" Canvas.Top="-160">
                <Rectangle.RenderTransform>
                    <SkewTransform AngleX="-18" />
                </Rectangle.RenderTransform>
            </Rectangle>
            <Rectangle Width="24" Height="1200" Fill="#FFF0D5" Opacity="0.9" Canvas.Left="815" Canvas.Top="-120">
                <Rectangle.RenderTransform>
                    <SkewTransform AngleX="-18" />
                </Rectangle.RenderTransform>
            </Rectangle>
            <Rectangle Width="260" Height="520" Stroke="#C4C4C4" StrokeThickness="3" Opacity="0.45" Canvas.Left="80" Canvas.Top="70">
                <Rectangle.RenderTransform>
                    <SkewTransform AngleX="-18" />
                </Rectangle.RenderTransform>
            </Rectangle>
            <Rectangle Width="260" Height="520" Stroke="#C4C4C4" StrokeThickness="3" Opacity="0.32" Canvas.Left="420" Canvas.Top="110">
                <Rectangle.RenderTransform>
                    <SkewTransform AngleX="-18" />
                </Rectangle.RenderTransform>
            </Rectangle>
            <Rectangle Width="190" Height="2" Fill="#CF6B00" Opacity="0.35" Canvas.Left="910" Canvas.Top="150">
                <Rectangle.RenderTransform>
                    <SkewTransform AngleX="-18" />
                </Rectangle.RenderTransform>
            </Rectangle>
            <Rectangle Width="260" Height="2" Fill="#CF6B00" Opacity="0.35" Canvas.Left="910" Canvas.Top="165">
                <Rectangle.RenderTransform>
                    <SkewTransform AngleX="-18" />
                </Rectangle.RenderTransform>
            </Rectangle>
            <Rectangle Width="220" Height="2" Fill="#CF6B00" Opacity="0.35" Canvas.Left="910" Canvas.Top="180">
                <Rectangle.RenderTransform>
                    <SkewTransform AngleX="-18" />
                </Rectangle.RenderTransform>
            </Rectangle>
        </Canvas>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Background="Transparent">
        <Grid Padding="40,30,40,40" RowSpacing="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel MaxWidth="1100" HorizontalAlignment="Center" Spacing="10">
                <TextBlock
                    x:Name="TitleText"
                    FontSize="38"
                    FontWeight="Black"
                    Foreground="#1B1F31"
                    CharacterSpacing="60"
                    TextWrapping="WrapWholeWords"
                    Text="Kill Confirm Overlay Advanced Settings" />
                <TextBlock
                    x:Name="InstructionText"
                    Style="{StaticResource SettingsCaptionTextStyle}"
                    FontSize="16"
                    Foreground="#474B57" />
                <TextBlock
                    x:Name="ShortcutText"
                    Style="{StaticResource SettingsCaptionTextStyle}"
                    FontSize="14"
                    TextWrapping="WrapWholeWords"
                    Foreground="#71737A" />
            </StackPanel>

            <Grid
                Grid.Row="1"
                MaxWidth="1040"
                HorizontalAlignment="Center"
                ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.15*" />
                    <ColumnDefinition Width="0.85*" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="14">
                    <Border Style="{StaticResource SettingsSectionCardStyle}">
                        <StackPanel Spacing="14">
                            <Grid RowSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Spacing="4">
                                    <TextBlock
                                        x:Name="VoiceCollectionsTitleText"
                                        Style="{StaticResource SettingsSectionTitleTextStyle}" />
                                    <TextBlock
                                        x:Name="VoiceCollectionsHintText"
                                        Style="{StaticResource SettingsCaptionTextStyle}" />
                                </StackPanel>

                                <StackPanel
                                    Grid.Row="1"
                                    Orientation="Horizontal"
                                    Spacing="12">
                                    <Button
                                        x:Name="ImportVoicePackButton"
                                        Style="{StaticResource SettingsHeaderButtonStyle}"
                                        Click="OnImportVoicePackClick" />
                                    <Button
                                        x:Name="ImportVoiceZipButton"
                                        Style="{StaticResource SettingsHeaderButtonStyle}"
                                        Click="OnImportVoiceZipClick" />
                                    <Button
                                        x:Name="CreateVoicePackButton"
                                        Style="{StaticResource SettingsPrimaryButtonStyle}"
                                        Click="OnCreateVoicePackClick" />
                                </StackPanel>
                            </Grid>

                            <TextBlock
                                x:Name="VoiceVisibleCountText"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="#2E88B8" />

                            <VariableSizedWrapGrid
                                x:Name="VoicePackListPanel"
                                Orientation="Horizontal"
                                ItemWidth="250"
                                ItemHeight="82" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsSectionCardStyle}">
                        <StackPanel Spacing="14">
                            <Grid RowSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Spacing="4">
                                    <TextBlock
                                        x:Name="IconCollectionsTitleText"
                                        Style="{StaticResource SettingsSectionTitleTextStyle}" />
                                    <TextBlock
                                        x:Name="IconCollectionsHintText"
                                        Style="{StaticResource SettingsCaptionTextStyle}" />
                                </StackPanel>

                                <StackPanel
                                    Grid.Row="1"
                                    Orientation="Horizontal"
                                    Spacing="12">
                                    <Button
                                        x:Name="ImportIconPackButton"
                                        Style="{StaticResource SettingsHeaderButtonStyle}"
                                        Click="OnImportIconPackClick" />
                                    <Button
                                        x:Name="ImportIconZipButton"
                                        Style="{StaticResource SettingsHeaderButtonStyle}"
                                        Click="OnImportIconZipClick" />
                                    <Button
                                        x:Name="CreateIconPackButton"
                                        Style="{StaticResource SettingsPrimaryButtonStyle}"
                                        Click="OnCreateIconPackClick" />
                                </StackPanel>
                            </Grid>

                            <TextBlock
                                x:Name="IconVisibleCountText"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="#2E88B8" />

                            <VariableSizedWrapGrid
                                x:Name="IconPackListPanel"
                                Orientation="Horizontal"
                                ItemWidth="250"
                                ItemHeight="82" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    Spacing="14">
                    <Border Style="{StaticResource SettingsSectionCardStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock
                                x:Name="StructureTitleText"
                                Style="{StaticResource SettingsSectionTitleTextStyle}" />
                            <TextBlock
                                x:Name="StructureBodyText"
                                Style="{StaticResource SettingsCaptionTextStyle}" />

                            <Border Style="{StaticResource MethodStepCardStyle}">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource MethodStepBadgeStyle}">
                                        <TextBlock Text="1" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="8">
                                        <TextBlock x:Name="StructureImportFolderTitleText" Style="{StaticResource MethodStepTitleTextStyle}" />
                                        <TextBlock x:Name="StructureImportFolderBodyText" Style="{StaticResource MethodStepBodyTextStyle}" />

                                        <Border Padding="10" Background="#F7F8FA" BorderBrush="#E2DDD3" BorderThickness="1" CornerRadius="14">
                                            <StackPanel Spacing="5">
                                                <TextBlock x:Name="StructureVoiceSpecTitleText" Style="{StaticResource MethodStepDetailTitleTextStyle}" />
                                                <TextBlock x:Name="StructureVoiceSpecBodyText" Style="{StaticResource MethodStepMonoTextStyle}" />
                                            </StackPanel>
                                        </Border>

                                        <Border Padding="10" Background="#FFF8EB" BorderBrush="#F2C078" BorderThickness="1" CornerRadius="14">
                                            <StackPanel Spacing="6">
                                                <TextBlock x:Name="StructureIconSpecTitleText" Style="{StaticResource MethodStepDetailTitleTextStyle}" />
                                                <TextBlock x:Name="StructureIconSpecSummaryText" Style="{StaticResource MethodStepBodyTextStyle}" Foreground="#8A4B00" />
                                                <Button
                                                    x:Name="IconSpecToggleButton"
                                                    Style="{StaticResource MethodInlineButtonStyle}"
                                                    HorizontalAlignment="Left"
                                                    Click="OnIconSpecToggleClick" />
                                                <TextBlock
                                                    x:Name="StructureIconSpecFullText"
                                                    Style="{StaticResource MethodStepMonoTextStyle}"
                                                    Visibility="Collapsed" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource MethodStepCardStyle}">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource MethodStepBadgeStyle}" Background="#2E88B8">
                                        <TextBlock Text="2" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock x:Name="StructureImportZipTitleText" Style="{StaticResource MethodStepTitleTextStyle}" />
                                        <TextBlock x:Name="StructureImportZipBodyText" Style="{StaticResource MethodStepBodyTextStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource MethodStepCardStyle}">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource MethodStepBadgeStyle}" Background="#1F2937">
                                        <TextBlock Text="3" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock x:Name="StructureCreatorTitleText" Style="{StaticResource MethodStepTitleTextStyle}" />
                                        <TextBlock x:Name="StructureCreatorBodyText" Style="{StaticResource MethodStepBodyTextStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Padding="12" Background="#FFF6E8" BorderBrush="#F2C078" BorderThickness="1" CornerRadius="16">
                                <TextBlock x:Name="StructureFileHintText" Style="{StaticResource MethodStepBodyTextStyle}" Foreground="#8A4B00" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsSectionCardStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock
                                x:Name="TipsTitleText"
                                Style="{StaticResource SettingsSectionTitleTextStyle}"
                                FontSize="18" />
                            <TextBlock
                                x:Name="TipsBodyText"
                                Style="{StaticResource SettingsCaptionTextStyle}" />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
    </Grid>
</Page>
